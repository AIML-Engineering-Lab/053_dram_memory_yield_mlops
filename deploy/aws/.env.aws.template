# ═══════════════════════════════════════════════════════════════
# P053 — AWS Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your AWS details:
#   cp deploy/aws/.env.aws.template deploy/aws/.env
#
# These values come from your AWS console after provisioning:
#   1. RDS PostgreSQL instance → MLFLOW_DB_HOST, MLFLOW_DB_PASSWORD
#   2. S3 bucket → S3_BUCKET
#   3. ECR repository → ECR_REPO
#   4. Region → AWS_DEFAULT_REGION
# ═══════════════════════════════════════════════════════════════

# ─── AWS Region ───
AWS_DEFAULT_REGION=us-west-2

# ─── RDS PostgreSQL (MLflow backend store) ───
# Create: aws rds create-db-instance \
#   --db-instance-identifier p053-mlflow \
#   --db-instance-class db.t3.micro \
#   --engine postgres --engine-version 16.4 \
#   --master-username mlflow --master-user-password <password> \
#   --allocated-storage 20
MLFLOW_DB_HOST=p053-mlflow.xxxxxxxxxxxx.us-west-2.rds.amazonaws.com
MLFLOW_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── S3 Bucket (MLflow artifacts) ───
# Create: aws s3 mb s3://p053-mlflow-artifacts --region us-west-2
S3_BUCKET=p053-mlflow-artifacts

# ─── ECR (Docker image) ───
# Create: aws ecr create-repository --repository-name 053-memory-yield-predictor
ECR_REPO=123456789012.dkr.ecr.us-west-2.amazonaws.com/053-memory-yield-predictor
IMAGE_TAG=latest

# ─── Grafana ───
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
